{
  "name": "quanton3d-final-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "prebuild": "node -e \"const fs=require('fs'),p='src/App.jsx';let s=fs.readFileSync(p,'utf8').replace(/\\r\\n/g,'\\n').split('\\n').filter(l=>!/^\\s*codex\\//.test(l)&&!/<<<<<<<|=======|>>>>>>>/.test(l)&&l.trim()!=='main').join('\\n');const m='export default App;';const i=s.indexOf(m);if(i>=0)s=s.slice(0,i+m.length);fs.writeFileSync(p,s.trimEnd()+'\\n')\""
  },
  "dependencies": {
    "axios": "^1.15.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "vite": "^8.0.10"
  }
}
